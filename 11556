<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pro Gear Monitor (Final Edition V11.1)</title>
<style>
    :root {
        --bg: #0b0e14; --panel: #151a22; --border: #2a3241;
        --cyan: #00f3ff; --pink: #ff003c; --yellow: #fce205; --text: #c9d1d9;
    }
    body { background: var(--bg); color: var(--text); margin: 0; font-family: 'Consolas', monospace; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
    
    header { padding: 15px 25px; background: #000; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; z-index: 100; position: relative; }
    h2 { margin: 0; font-size: 22px; color: #fff; letter-spacing: 2px; text-transform: uppercase; text-shadow: 0 0 10px rgba(255,255,255,0.3); }
    .version-tag { color: var(--cyan); font-weight: bold; }
    .local-tag { color: #fce205; font-size: 12px; vertical-align: middle; margin-left: 10px; border: 1px solid #fce205; padding: 2px 6px; border-radius: 4px; box-shadow: 0 0 8px rgba(252,226,5,0.5); }
    
    .control-group { display: flex; gap: 15px; align-items: center; }
    .sys-btn { background: transparent; color: var(--cyan); border: 1px solid var(--cyan); padding: 8px 20px; font-size: 16px; font-family: 'Consolas', monospace; font-weight: bold; cursor: pointer; transition: all 0.3s; border-radius: 4px; text-transform: uppercase; }
    .sys-btn:hover { background: var(--cyan); color: #000; box-shadow: 0 0 15px var(--cyan); }
    .sys-btn.active-pink { color: var(--pink); border-color: var(--pink); }
    .sys-btn.active-pink:hover { background: var(--pink); color: #fff; box-shadow: 0 0 15px var(--pink); }
    
    .status { display: flex; align-items: center; gap: 10px; font-size: 14px; color: #888; }
    .led { width: 12px; height: 12px; border-radius: 50%; background: #333; display: inline-block; }
    .led.on { background: #0f0; box-shadow: 0 0 10px #0f0; }
    .led.paused { background: var(--yellow); box-shadow: 0 0 10px var(--yellow); }
    
    .profile-bar { background: #0d1117; padding: 10px 25px; border-bottom: 2px solid var(--border); display: flex; align-items: center; gap: 15px; z-index: 90; position: relative; }
    .profile-bar span { color: var(--text); font-weight: bold; font-size: 14px; }
    select { background: #000; color: var(--yellow); border: 1px solid var(--border); padding: 5px 10px; font-family: 'Consolas', monospace; font-size: 16px; font-weight: bold; outline: none; border-radius: 4px; min-width: 200px; cursor: pointer; }
    .sys-btn.small { padding: 5px 12px; font-size: 12px; }
    
    .content-wrapper { flex-grow: 1; position: relative; overflow: hidden; }
    
    #view-spectrogram { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #000; z-index: 1; }
    #spectrogram { display: block; width: 100%; height: 100%; image-rendering: pixelated; }
    
    #view-dashboard { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; justify-content: space-around; align-items: center; background: rgba(11, 14, 20, 0.9); padding: 20px; box-sizing: border-box; gap: 20px; z-index: 10; transition: opacity 0.4s ease; backdrop-filter: blur(5px); }
    #view-dashboard.hidden { opacity: 0; pointer-events: none; }
    
    .panel { text-align: center; flex: 1; background: var(--panel); padding: 40px 20px; border-radius: 12px; border: 1px solid var(--border); box-shadow: inset 0 0 20px rgba(0,0,0,0.5); }
    .panel-title { font-size: 18px; color: #777; text-transform: uppercase; letter-spacing: 4px; margin-bottom: 30px; }
    .panel-value { font-size: 90px; font-weight: bold; color: var(--cyan); text-shadow: 0 0 30px rgba(0,243,255,0.4); }
    .panel-value.db { color: var(--pink); text-shadow: 0 0 30px rgba(255,0,60,0.4); }
    .panel-value.gear { color: var(--yellow); text-shadow: 0 0 30px rgba(252,226,5,0.4); }
    .panel-unit { font-size: 24px; color: #666; margin-left: 10px; }

    .calibration-bar { display: flex; justify-content: space-around; background: #05070a; padding: 15px; border-top: 1px solid var(--border); z-index: 100; position: relative; }
    .calib-box { text-align: center; width: 18%; }
    .calib-btn { width: 100%; background: #1a202c; color: #fff; border: 1px solid #444; padding: 10px; font-size: 14px; font-family: 'Consolas', monospace; cursor: pointer; border-radius: 4px; transition: 0.2s; }
    .calib-btn:hover { background: #2d3748; border-color: var(--cyan); color: var(--cyan); }
    .calib-val { display: block; margin-top: 8px; color: var(--cyan); font-size: 13px; font-weight: bold; }
    .calib-val.unset { color: #555; font-weight: normal; }
    .calib-clear { display: inline-block; margin-top: 5px; color: var(--pink); font-size: 11px; cursor: pointer; text-transform: uppercase; font-weight: bold; padding: 2px 5px; border-radius: 3px; }
    .calib-clear:hover { background: rgba(255,0,60,0.1); }
    .calib-clear.hide { display: none; }
</style>
</head>
<body>
<header>
    <h2>PRO ACOUSTIC SYSTEM <span class="version-tag">(V11.1)</span><span class="local-tag">EDGE COMPUTING</span></h2>
    <div class="control-group">
        <button id="btn-mic" class="sys-btn" onclick="startMic()">START MIC</button>
        <button id="btn-pause" class="sys-btn active-pink" onclick="togglePause()">PAUSE SYSTEM</button>
        <button id="btn-view" class="sys-btn" onclick="toggleView()">HIDE DASHBOARD</button>
        <div class="status"><span class="led" id="led"></span><span id="status-text">OFFLINE</span></div>
    </div>
</header>

<div class="profile-bar">
    <span>DEVICE PROFILE: </span>
    <select id="profile-select" onchange="switchProfile(this.value)"></select>
    <button class="sys-btn small" onclick="addProfile()">+ ADD NEW</button>
    <button class="sys-btn small active-pink" onclick="deleteProfile()">- DELETE</button>
    
    <button class="sys-btn small" style="margin-left:auto; color: #fff; border-color: #555;" onclick="exportData()">[💾] EXPORT DATA</button>
    <button class="sys-btn small" style="color: #fff; border-color: #555;" onclick="document.getElementById('import-file').click()">[📂] IMPORT DATA</button>
    <input type="file" id="import-file" style="display:none" accept=".json" onchange="importData(event)">
</div>

<div class="content-wrapper">
    <div id="view-spectrogram"><canvas id="spectrogram"></canvas></div>
    <div id="view-dashboard">
        <div class="panel"><div class="panel-title">Peak Frequency</div><div><span id="hz-val" class="panel-value">0</span><span class="panel-unit">Hz</span></div></div>
        <div class="panel"><div class="panel-title">Volume (dB)</div><div><span id="db-val" class="panel-value db">0.0</span><span class="panel-unit">dB</span></div></div>
        <div class="panel"><div class="panel-title">Current Gear</div><div><span id="gear-val" class="panel-value gear">-</span></div></div>
    </div>
</div>

<div class="calibration-bar" id="calib-bar">
    <div class="calib-box"><button class="calib-btn" onclick="recordGear('1')">Rec Gear 1</button><span class="calib-val unset" id="target-1">Not Set</span><span class="calib-clear hide" id="clear-1" onclick="clearGear('1')">[X] Reset</span></div>
    <div class="calib-box"><button class="calib-btn" onclick="recordGear('2')">Rec Gear 2</button><span class="calib-val unset" id="target-2">Not Set</span><span class="calib-clear hide" id="clear-2" onclick="clearGear('2')">[X] Reset</span></div>
    <div class="calib-box"><button class="calib-btn" onclick="recordGear('3')">Rec Gear 3</button><span class="calib-val unset" id="target-3">Not Set</span><span class="calib-clear hide" id="clear-3" onclick="clearGear('3')">[X] Reset</span></div>
    <div class="calib-box"><button class="calib-btn" onclick="recordGear('4')">Rec Gear 4</button><span class="calib-val unset" id="target-4">Not Set</span><span class="calib-clear hide" id="clear-4" onclick="clearGear('4')">[X] Reset</span></div>
    <div class="calib-box"><button class="calib-btn" onclick="recordGear('5')">Rec Gear 5</button><span class="calib-val unset" id="target-5">Not Set</span><span class="calib-clear hide" id="clear-5" onclick="clearGear('5')">[X] Reset</span></div>
</div>

<script>
    // ==========================================
    // 1. Local Storage Database Management
    // ==========================================
    let dbData = {"Device A": {"1": [], "2": [], "3": [], "4": [], "5": []}};
    let activeProfile = "Device A";
    const DB_KEY = "pro_gear_db_v11";

    function loadData() {
        try {
            const saved = localStorage.getItem(DB_KEY);
            if (saved) {
                const parsed = JSON.parse(saved);
                if (Object.keys(parsed).length > 0) {
                    dbData = parsed;
                    activeProfile = Object.keys(dbData)[0];
                }
            }
        } catch (e) { console.error("Load error", e); }
    }

    function saveData() {
        try {
            localStorage.setItem(DB_KEY, JSON.stringify(dbData));
            updateUI();
        } catch (e) { console.error("Save error", e); }
    }

    loadData();

    function updateUI() {
        const sel = document.getElementById('profile-select');
        const currentProfiles = Array.from(sel.options).map(o => o.value).join(',');
        const newProfiles = Object.keys(dbData).join(',');

        if (currentProfiles !== newProfiles) {
            sel.innerHTML = '';
            Object.keys(dbData).forEach(p => { sel.add(new Option(p, p)); });
        }
        sel.value = activeProfile;

        // --- 這裡就是你原本斷掉的地方 ---
        for (let i = 1; i <= 5; i++) {
            const dataArr = dbData[activeProfile][i];
            const targetEl = document.getElementById(`target-${i}`);
            const clearEl = document.getElementById(`clear-${i}`);
            
            if (dataArr && dataArr.length > 0) {
                const avgHz = dataArr.reduce((a, b) => a + b, 0) / dataArr.length;
                targetEl.textContent = `${avgHz.toFixed(1)} Hz`;
                targetEl.classList.remove('unset');
                clearEl.classList.remove('hide');
            } else {
                targetEl.textContent = 'Not Set';
                targetEl.classList.add('unset');
                clearEl.classList.add('hide');
            }
        }
    }

    // ==========================================
    // 2. Profile Management
    // ==========================================
    function switchProfile(p) { activeProfile = p; updateUI(); }
    function addProfile() { 
        const p = prompt("Enter new device profile name:"); 
        if(p && !dbData[p]) { dbData[p] = {"1":[], "2":[], "3":[], "4":[], "5":[]}; activeProfile = p; saveData(); } 
    }
    function deleteProfile() { 
        if(Object.keys(dbData).length > 1 && confirm(`Delete profile: ${activeProfile}?`)) { 
            delete dbData[activeProfile]; activeProfile = Object.keys(dbData)[0]; saveData(); 
        } else if (Object.keys(dbData).length <= 1) {
            alert("Cannot delete the last profile.");
        }
    }
    function exportData() {
        const blob = new Blob([JSON.stringify(dbData)], {type: 'application/json'});
        const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'pro_gear_data.json'; a.click();
    }
    function importData(e) {
        const file = e.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (ev) => {
            try { dbData = JSON.parse(ev.target.result); activeProfile = Object.keys(dbData)[0]; saveData(); } 
            catch(err) { alert("Invalid JSON file format!"); }
        };
        reader.readAsText(file);
    }

    // ==========================================
    // 3. Audio Processing & Spectrogram
    // ==========================================
    let audioCtx, analyser, dataArray, source, isRunning = false, isPaused = false;
    const canvas = document.getElementById('spectrogram');
    const ctx = canvas.getContext('2d', { willReadFrequently: true });

    async function startMic() {
        if (isRunning) return;
        try {
            const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            analyser = audioCtx.createAnalyser();
            analyser.fftSize = 4096; // 提高頻率解析度
            source = audioCtx.createMediaStreamSource(stream);
            source.connect(analyser);
            dataArray = new Uint8Array(analyser.frequencyBinCount);
            
            isRunning = true;
            document.getElementById('led').className = 'led on';
            document.getElementById('status-text').textContent = 'ONLINE';
            document.getElementById('btn-mic').textContent = 'MIC ACTIVE';
            document.getElementById('btn-mic').style.color = '#0f0';
            
            drawLoop();
        } catch (err) { alert("Microphone access denied or error: " + err); }
    }

    function togglePause() {
        if (!isRunning) return;
        isPaused = !isPaused;
        document.getElementById('btn-pause').textContent = isPaused ? 'RESUME SYSTEM' : 'PAUSE SYSTEM';
        document.getElementById('btn-pause').classList.toggle('active-pink');
        document.getElementById('led').className = isPaused ? 'led paused' : 'led on';
        document.getElementById('status-text').textContent = isPaused ? 'PAUSED' : 'ONLINE';
    }

    function toggleView() {
        const dash = document.getElementById('view-dashboard');
        dash.classList.toggle('hidden');
        const btn = document.getElementById('btn-view');
        btn.textContent = dash.classList.contains('hidden') ? 'SHOW DASHBOARD' : 'HIDE DASHBOARD';
    }

    function drawLoop() {
        requestAnimationFrame(drawLoop);
        if (isPaused || !isRunning) return;

        analyser.getByteFrequencyData(dataArray);
        
        // Find Peak Frequency
        let maxVal = -Infinity;
        let maxIndex = -1;
        for(let i = 0; i < dataArray.length; i++) {
            if (dataArray[i] > maxVal) { maxVal = dataArray[i]; maxIndex = i; }
        }

        const nyquist = audioCtx.sampleRate / 2;
        // 過濾雜音閾值 (大於 50 才算有效聲音)
        const peakHz = maxVal > 50 ? (maxIndex * nyquist) / dataArray.length : 0; 
        const db = maxVal > 0 ? 20 * Math.log10(maxVal / 255) : -100;

        document.getElementById('hz-val').textContent = peakHz.toFixed(1);
        document.getElementById('db-val').textContent = db.toFixed(1);

        matchGear(peakHz);

        // Draw simple scrolling spectrogram
        if(canvas.width !== canvas.offsetWidth) canvas.width = canvas.offsetWidth;
        if(canvas.height !== canvas.offsetHeight) canvas.height = canvas.offsetHeight;
        
        const imgData = ctx.getImageData(1, 0, canvas.width - 1, canvas.height);
        ctx.putImageData(imgData, 0, 0);

        for(let i = 0; i < dataArray.length; i++) {
            const y = canvas.height - (i / dataArray.length) * canvas.height;
            const val = dataArray[i];
            ctx.fillStyle = `rgb(${val}, ${Math.max(0, val - 100)}, ${Math.max(0, 255 - val)})`;
            ctx.fillRect(canvas.width - 1, y, 1, canvas.height / dataArray.length);
        }
    }

    // ==========================================
    // 4. Calibration & Gear Matching
    // ==========================================
    function recordGear(gear) {
        const currentHz = parseFloat(document.getElementById('hz-val').textContent);
        if (currentHz > 0) {
            dbData[activeProfile][gear].push(currentHz);
            // 只保留最近 5 次的採樣來計算平均值
            if(dbData[activeProfile][gear].length > 5) dbData[activeProfile][gear].shift();
            saveData();
        } else {
            alert("No clear audio detected! Please ensure the mic is running and picking up sound.");
        }
    }

    function clearGear(gear) {
        dbData[activeProfile][gear] = [];
        saveData();
    }

    function matchGear(currentHz) {
        if (currentHz <= 0) return document.getElementById('gear-val').textContent = '-';
        
        let closestGear = '-';
        let minDiff = Infinity;
        const tolerance = 60; // 頻率容錯範圍 (+- 60Hz)

        for(let i = 1; i <= 5; i++) {
            const arr = dbData[activeProfile][i];
            if(arr && arr.length > 0) {
                const targetHz = arr.reduce((a,b) => a+b, 0) / arr.length;
                const diff = Math.abs(currentHz - targetHz);
                if (diff < tolerance && diff < minDiff) {
                    minDiff = diff;
                    closestGear = i;
                }
            }
        }
        document.getElementById('gear-val').textContent = closestGear;
    }

    // Init
    updateUI();
</script>
</body>
</html>
